---
import Layout from '~/layouts/PageLayout.astro';

import Header from '~/components/widgets/Header.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Steps from '~/components/widgets/Steps.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import { getPermalink } from '~/utils/permalinks';

const metadata = {
  title: 'Apurba Podder — Full Stack Developer',
  description: 'Personal portfolio of Apurba Podder, specializing in Full Stack Development, Shopify, Laravel, and AI Automation.',
};
---

<Layout metadata={metadata}>
  <Fragment slot="announcement"></Fragment>
  <Fragment slot="header">
    <Header
      links={[
        { text: 'Home', href: '#' },
        { text: 'About', href: '#about' },
        { text: 'Skills', href: '#skills' },
        { text: 'Projects', href: '#projects' },
        { text: 'Contact', href: 'mailto:apurba@apurba.me' },
        { text: 'GitHub', href: 'https://github.com/apurbajnu', target: '_blank' },
      ]}
      actions={[
        {
          text: 'Contact Me',
          href: 'mailto:apurba@apurba.me',
        },
      ]}
      isSticky
      showToggleTheme
    />
  </Fragment>

  <!-- Hero Widget ******************* -->

  <Hero
    id="hero"
    title="Apurba Podder"
    tagline="Full Stack Developer & Tech Enthusiast"
    actions={[
      { variant: 'primary', text: 'View Projects', href: '#projects' },
      { variant: 'secondary', text: 'Contact Me', href: 'mailto:apurba@apurba.me' }
    ]}
  >
    <Fragment slot="subtitle">
      I build scalable web applications, automate complex workflows, and explore the boundaries of modern technology.
      Specializing in <span class="text-accent dark:text-white font-semibold">Shopify development</span>,
      <span class="text-accent dark:text-white font-semibold">Laravel</span>, and
      <span class="text-accent dark:text-white font-semibold">AI automation</span>.
      Welcome to my personal corner of the internet.
    </Fragment>
  </Hero>

  <!-- Content Widget **************** -->

  <Content
    id="about"
    columns={3}
    items={[
      {
        icon: 'tabler:brand-github',
        callToAction: {
          target: '_blank',
          text: 'GitHub',
          href: 'https://github.com/apurbajnu',
        },
      },
      {
        icon: 'tabler:brand-linkedin',
        callToAction: {
          target: '_blank',
          text: 'LinkedIn',
          href: '#',
        },
      },
      {
        icon: 'tabler:mail',
        callToAction: {
          text: 'Email',
          href: 'mailto:apurba@apurba.me',
        },
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1498050108023-c5249f4df085?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=774&q=80',
      alt: 'Developer workspace',
      loading: 'eager',
    }}
  >
    <Fragment slot="content">
      <h2 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">About Me</h2>
      <p>
        I'm a passionate Full Stack Developer who loves turning ideas into reality through code.
        My journey in web development has taken me through various technologies and frameworks,
        allowing me to build robust and scalable applications.
      </p>
      <br />
      <p>
        Currently focused on building automation tools for e-commerce platforms, creating web scrapers,
        and integrating AI solutions into real-world applications. I believe in writing clean,
        maintainable code and always learning new technologies.
      </p>
      <br />
      <p>When I'm not coding, you can find me exploring new tech trends, contributing to open source, or automating everyday tasks.</p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Steps Widget - Experience ****************** -->

  <Steps
    id="experience"
    title="Work Experience"
    items={[
      {
        title:
          'Full Stack Developer <br /> <span class="font-normal">Freelance & Independent Projects</span> <br /> <span class="text-sm font-normal">2020 - Present</span>',
        description: `Building scalable web applications using Laravel, Node.js, and modern JavaScript frameworks. <br />
        Developing Shopify apps and automation tools for e-commerce businesses. <br />
        Creating web scrapers and data extraction solutions for various industries. <br />
        Implementing AI automation workflows to streamline business processes.`,
        icon: 'tabler:briefcase',
      },
      {
        title:
          'Projects & Contributions <br /> <span class="font-normal">Open Source & Personal Ventures</span> <br /> <span class="text-sm font-normal">Ongoing</span>',
        description: `Developing and maintaining multiple GitHub projects focused on automation tools. <br />
        Building Shopify app crawler and analysis tools. <br />
        Contributing to open source projects and learning from the developer community.`,
        icon: 'tabler:code',
      },
    ]}
    classes={{ container: 'max-w-3xl' }}
  />

  <!-- Features3 Widget - Skills ************** -->

  <Features3
    id="skills"
    title="Technical Skills"
    subtitle="Technologies and tools I work with regularly."
    columns={3}
    defaultIcon="tabler:point-filled"
    items={[
      {
        title: 'Full Stack Development',
        description: 'Building end-to-end web applications with modern frameworks and best practices.',
      },
      {
        title: 'Shopify Development',
        description: 'Creating custom Shopify apps, themes, and automation solutions for e-commerce.',
      },
      {
        title: 'Laravel & PHP',
        description: 'Developing robust backend applications with Laravel framework and PHP.',
      },
      {
        title: 'JavaScript & Node.js',
        description: 'Building scalable server-side applications and RESTful APIs with Node.js.',
      },
      {
        title: 'Web Scraping & Automation',
        description: 'Creating intelligent data extraction tools and workflow automation solutions.',
      },
      {
        title: 'AI Integration',
        description: 'Integrating AI/ML capabilities into applications for enhanced functionality.',
      },
      {
        title: 'Database Management',
        description: 'Designing and managing databases with MySQL, MongoDB, and other data stores.',
      },
      {
        title: 'API Development',
        description: 'Building and consuming RESTful and GraphQL APIs for seamless integrations.',
      },
      {
        title: 'DevOps & Deployment',
        description: 'Setting up CI/CD pipelines, managing servers, and automated deployments.',
      },
    ]}
  />

  <!-- Content Widget - Projects **************** -->

  <Content
    id="projects"
    title="Featured Projects"
    subtitle="Some of the projects I've worked on recently."
    isReversed
    items={[
      {
        title: 'Technology Stack:',
        description:
          'Node.js, Express, MongoDB, Puppeteer for web scraping, PM2 for process management.',
      },
      {
        title: 'Key Features:',
        description:
          'Automated data extraction from Shopify app store, RESTful API for data access, webhook-based auto-deployment, comprehensive analytics and reporting.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=928&q=80',
      alt: 'Analytics Dashboard',
    }}
    callToAction={{
      target: '_blank',
      text: 'View on GitHub',
      icon: 'tabler:brand-github',
      href: 'https://github.com/apurbajnu',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Shopify App Crawler
      </h3>
      <p class="text-muted dark:text-slate-400">
        An automated scraping and analytics tool for Shopify applications.
        Crawls the Shopify app store, extracts app data, and provides insights through a RESTful API.
      </p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isReversed
    isAfterContent={true}
    items={[
      {
        title: 'Tech Stack:',
        description: 'Astro, Tailwind CSS, Node.js, PM2, GitHub Webhooks for CI/CD.',
      },
      {
        title: 'Deployment:',
        description: 'Automated deployment pipeline using GitHub webhooks. Every push triggers automatic build and deployment with zero downtime.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1555066931-4365d14bab8c?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=774&q=80',
      alt: 'Portfolio Website',
    }}
    callToAction={{
      target: '_blank',
      text: 'Source Code',
      icon: 'tabler:brand-github',
      href: 'https://github.com/apurbajnu/apurba.me',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Personal Portfolio
      </h3>
      <p class="text-muted dark:text-slate-400">
        Built with Astro and Tailwind CSS, featuring a modern design system,
        dark mode support, and automated deployments. Optimized for performance
        and SEO.
      </p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- CallToAction Widget *********** -->

  <CallToAction
    title="Let's Work Together"
    subtitle="Have a project in mind or want to collaborate?"
    actions={[
      {
        variant: 'primary',
        text: 'Get In Touch',
        href: 'mailto:apurba@apurba.me',
      },
      {
        variant: 'secondary',
        text: 'View GitHub',
        href: 'https://github.com/apurbajnu',
        target: '_blank',
      },
    ]}
  />

  <!-- BlogLatestPost Widget **************** -->

  <BlogLatestPosts
    title="Latest From The Blog"
    information={`Coming soon: Technical articles, tutorials, and insights about web development, automation, and the technologies I work with.`}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </BlogLatestPosts>
</Layout>

---
import Layout from '../layouts/Layout.astro';

const name = "Apurba Podder";
const title = "Full Stack Developer & Tech Enthusiast";
const bio = "I build scalable web applications and explore the boundaries of modern technology. Welcome to my personal corner of the internet.";
---

<Layout>
	<main>
		<section class="hero">
			<h1>{name}</h1>
			<p class="title">{title}</p>
			<p class="bio">{bio}</p>
			<div class="cta">
				<a href="https://github.com/apurbajnu" class="button">GitHub</a>
				<a href="mailto:apurba@apurba.me" class="button secondary">Contact Me</a>
			</div>
		</section>

		<section class="links">
			<h2>Current Projects</h2>
			<div class="grid">
				<div class="card">
					<h3>Shopify Tools</h3>
					<p>Specialized scrapers and automation for Shopify stores.</p>
				</div>
				<div class="card">
					<h3>Portfolio</h3>
					<p>This Astro-powered site with automated deployment.</p>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	main {
		max-width: 800px;
		margin: 0 auto;
		padding: 4rem 2rem;
		font-family: 'Inter', system-ui, sans-serif;
		color: #1a1a1a;
	}

	.hero {
		text-align: center;
		margin-bottom: 4rem;
	}

	h1 {
		font-size: 3.5rem;
		margin: 0;
		background: linear-gradient(to right, #3245ff, #bc52ee);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
	}

	.title {
		font-size: 1.5rem;
		color: #4b5563;
		margin: 1rem 0;
		font-weight: 500;
	}

	.bio {
		font-size: 1.125rem;
		line-height: 1.6;
		color: #6b7280;
		max-width: 600px;
		margin: 0 auto;
	}

	.cta {
		margin-top: 2rem;
		display: flex;
		gap: 1rem;
		justify-content: center;
	}

	.button {
		padding: 0.75rem 1.5rem;
		border-radius: 8px;
		text-decoration: none;
		font-weight: 600;
		transition: all 0.2s;
	}

	.button:not(.secondary) {
		background: #3245ff;
		color: white;
	}

	.button.secondary {
		border: 1px solid #e5e7eb;
		color: #374151;
	}

	.button:hover {
		transform: translateY(-2px);
		box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
	}

	.links h2 {
		font-size: 1.5rem;
		border-bottom: 2px solid #f3f4f6;
		padding-bottom: 0.5rem;
		margin-bottom: 2rem;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
		gap: 1.5rem;
	}

	.card {
		padding: 1.5rem;
		border: 1px solid #e5e7eb;
		border-radius: 12px;
		transition: border-color 0.2s;
	}

	.card:hover {
		border-color: #3245ff;
	}

	.card h3 {
		margin: 0 0 0.5rem 0;
		color: #111827;
	}

	.card p {
		margin: 0;
		color: #6b7280;
		font-size: 0.875rem;
	}
</style>

---
import Layout from '../layouts/Layout.astro';

const posts = [
	{
		title: "Automating Shopify with Node.js and AI",
		description: "A demo post exploring how to leverage modern AI APIs to streamline e-commerce operations.",
		date: "2024-03-30",
		slug: "/blog/first-post"
	}
];
---

<Layout>
	<main>
		<section class="blog-header">
			<span class="sub">Insights & Engineering</span>
			<h1>Engineering Blog</h1>
			<p>Sharing my journey in full-stack development, Shopify engineering, and AI automation.</p>
		</section>

		<section class="posts">
			{posts.map(post => (
				<article class="post-card">
					<span class="date">{post.date}</span>
					<h2><a href={post.slug}>{post.title}</a></h2>
					<p>{post.description}</p>
					<a href={post.slug} class="read-more">Read Article →</a>
				</article>
			))}
		</section>
	</main>
</Layout>

<style>
	main {
		max-width: 800px;
		margin: 0 auto;
		padding: 6rem 1.5rem;
	}

	.blog-header {
		text-align: center;
		margin-bottom: 4rem;
	}

	.sub {
		color: var(--primary);
		font-weight: 700;
		text-transform: uppercase;
		font-size: 0.75rem;
		letter-spacing: 0.1em;
	}

	h1 {
		font-size: 3.5rem;
		margin: 0.5rem 0;
		letter-spacing: -0.02em;
	}

	p {
		color: var(--text-muted);
		font-size: 1.125rem;
	}

	.posts {
		display: grid;
		gap: 3rem;
	}

	.post-card {
		padding: 2rem;
		border-radius: 24px;
		border: 1px solid var(--border);
		transition: transform 0.2s ease, border-color 0.2s;
	}

	.post-card:hover {
		transform: translateY(-4px);
		border-color: var(--primary);
	}

	.date {
		font-size: 0.875rem;
		color: var(--text-muted);
	}

	.post-card h2 {
		font-size: 1.75rem;
		margin: 0.5rem 0 1rem 0;
	}

	.post-card h2 a {
		text-decoration: none;
		color: var(--text-main);
	}

	.post-card p {
		font-size: 1rem;
		margin-bottom: 1.5rem;
		line-height: 1.6;
	}

	.read-more {
		color: var(--primary);
		text-decoration: none;
		font-weight: 600;
	}
</style>
